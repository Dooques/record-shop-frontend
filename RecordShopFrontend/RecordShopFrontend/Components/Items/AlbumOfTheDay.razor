@using RecordShopFrontend.Models

<div class="card">
	<div class="columns is-gapless is-vcentered">
		<div class="column is-one-third">
			<NavLink href=@($"/albums/{Album.Id}")>
				<div class="card-img ">
					<figure class="img is-4by3 ">
						@if (Album.CoverUrl != "")
						{
							<img src="@Album.CoverUrl"
								 alt="Album Cover"/>
						}
					</figure>
				</div>
			</NavLink>
		</div>
		<div class="column">
			<div class="card-content">
				<p class="title">@Album.Title</p>
				<p class="subtitle">@Album.Artist - @Album.Genre</p>
			</div>
		</div>
	</div>
</div>


@code {
	[Parameter]
	public required Album Album { get; set; }
}
